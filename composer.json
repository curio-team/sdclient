{
    "name": "curio/sdclient",
    "description": "Client for sdlogin",
    "type": "library",
    "license": "CC-BY-NC-SA-4.0",
    "authors": [
        {
            "name": "Bart Roos"
        },
        {
            "name": "luttje"
        }
    ],
    "minimum-stability": "stable",
    "require": {
        "lcobucci/jwt": "4.0.4",
        "guzzlehttp/guzzle": "^7.0",
        "illuminate/contracts": "^8.0|^9.0|^10.0"
    },
    "autoload": {
        "psr-4": {
            "Curio\\SdClient\\": "src"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Curio\\SdClient\\SdClientServiceProvider"
            ]
        }
    },
    "require-dev": {
        "laravel/pint": "^1.14",
        "orchestra/testbench": "^8.0|^9.0",
        "phpunit/phpunit": "^10.0|^11.0"
    },
    "autoload-dev": {
        "psr-4": {
            "Curio\\SdClient\\Tests\\": "tests",
            "App\\Models\\": "tests/Stubs",
            "App\\Http\\Controllers\\": "tests/Stubs/Controllers"
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit"
    }
}