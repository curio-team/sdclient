includes:
    - vendor/larastan/larastan/extension.neon
    - vendor/nesbot/carbon/extension.neon

parameters:

    paths:
        - src/

    # Level 10 is the highest level
    level: 5

    ignoreErrors:
        -
            # Livewire wraps redirect() with its own class at runtime; PHPStan can't see through that
            identifier: identical.alwaysFalse
            path: src/SdApi.php
